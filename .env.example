# GB Golf Optimizer environment variables
# Copy this file to .env and fill in real values:
#   cp .env.example .env

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/gbgolf

# DataGolf Scratch Plus API key (get from datagolf.com account)
DATAGOLF_API_KEY=your-api-key-here

# Flask secret key for session cookies (change to a random string)
SECRET_KEY=change-this-to-a-random-string

# Flask app location (for flask CLI commands like flask db migrate)
FLASK_APP=gbgolf.web:create_app
